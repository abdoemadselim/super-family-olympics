    {"id": "m289", "text": "ما المعادلات التفاضلية؟", "answer": "معادلات تحتوي على مشتقات دالة مجهولة، تُستخدم في نمذجة الظواهر", "for": "adult"},
    {"id": "m290", "text": "ما التحليل العددي؟", "answer": "طرق رياضية لحل معادلات بالتقريب عبر الحاسوب", "for": "adult"},
    {"id": "m291", "text": "ما بحث العمليات؟", "answer": "تطبيق الرياضيات لتحسين اتخاذ القرارات وتحسين الموارد", "for": "adult"},
