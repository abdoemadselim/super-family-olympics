    {"id": "m249", "text": "ما النسبة الذهبية؟", "answer": "نحو 1.618، تظهر في الطبيعة والفن", "for": "adult"},
    {"id": "m250", "text": "ما قانون الأسس: a^m × a^n = ؟", "answer": "a^(m+n)", "for": "adult"},
